# EmailJS Configuration
# 1. Crée un compte sur https://www.emailjs.com/
# 2. Crée un Service (Gmail, Outlook, etc.) → copie le Service ID
# 3. Crée un Template avec les variables : {{from_name}}, {{reply_to}}, {{phone}}, {{subject}}, {{message}}
# 4. Copie ta Public Key depuis Account > General

NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key
